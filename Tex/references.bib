	publisher = {American Physical Society},
	author = {Zhang, Dongting and Le, Tian and Lv, Baijiang and Yin, Lichang and Chen, Chufan and Nie, Zhiyong and Su, Dajun and Yuan, Huiqiu and Xu, Zhu-An and Lu, Xin},
	month = jun,
	year = {2021},
	pages = {214508},
	file = {APS Snapshot:/home/jrose/Zotero/storage/8TTZND6G/PhysRevB.103.html:text/html;Full Text PDF:/home/jrose/Zotero/storage/WFH3PXTW/Zhang et al. - 2021 - Full superconducting gap and type-I to type-II superconductivity transition in single crystalline \$ .pdf:application/pdf},
}

@article{cocemasov_phonon_2015,
	title = {Phonon {Engineering} of the {Specific} {Heat} of {Twisted} {Bilayer} {Graphene}: {The} {Role} of the {Out}-of-{Plane} {Phonon} {Modes}},
	abstract = {We investigated theoretically the specific heat of graphene, bilayer graphene and twisted bilayer graphene taking into account the exact phonon dispersion and density of states for each polarization branch. It is shown that contrary to a conventional believe the dispersion of the outof-plane acoustic phonons – referred to as ZA phonons – deviates strongly from a parabolic law starting from the frequencies as low as {\textasciitilde}100 cm-1. This leads to the frequency-dependent ZA phonon density of states and the breakdown of the linear dependence of the specific heat on temperature T. We established that ZA phonons determine the specific heat for T ≤ 200 K while contributions from both in-plane and out-of-plane acoustic phonons are dominant for 200 K ≤ T ≤ 500 K. In the high-temperature limit, T{\textgreater}1000 K, the optical and acoustic phonons contribute approximately equally to the specific heat. The Debye temperature for graphene and twisted bilayer graphene was calculated to be around {\textasciitilde}1861 – 1864 K. Our results suggest that the thermodynamic properties of materials such as bilayer graphene can be controlled at the atomic scale by rotation of the sp2-carbon planes.},
	language = {en},
	author = {Cocemasov, Alexandr I and Nika, Denis L and Balandin, Alexander A},
	year = {2015},
	file = {PDF:/home/jrose/Zotero/storage/RHCIPRBE/Cocemasov et al. - 2015 - Phonon Engineering of the Specific Heat of Twisted Bilayer Graphene The Role of the Out-of-Plane Ph.pdf:application/pdf},
}

