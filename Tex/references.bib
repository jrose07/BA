@article{hanisch_lattice_1997,
	title = {Lattice dependence of saturated ferromagnetism in the {Hubbard} model},
	volume = {56},
	url = {https://link.aps.org/doi/10.1103/PhysRevB.56.13960},
	doi = {10.1103/PhysRevB.56.13960},
	abstract = {We investigate the instability of the saturated ferromagnetic ground state (Nagaoka state) in the Hubbard model on various lattices in dimensions 𝑑 =2 and 𝑑 =3. A variational resolvent approach is developed for the Nagaoka instability both for 𝑈 =∞ and for 𝑈 {\textless}∞ which can easily be evaluated in the thermodynamic limit on all common lattices. Our results significantly improve former variational bounds for a possible Nagaoka regime in the ground-state phase diagram of the Hubbard model. We show that a pronounced particle-hole asymmetry in the density of states and a diverging density of states at the lower band edge are the most important features in order to stabilize Nagaoka ferromagnetism, particularly in the low-density limit.},
	number = {21},
	urldate = {2026-06-18},
	journal = {Phys. Rev. B},
	publisher = {American Physical Society},
	author = {Hanisch, Thoralf and Uhrig, Götz S. and Müller-Hartmann, Erwin},
	month = dec,
	year = {1997},
	pages = {13960--13982},
	file = {APS Snapshot:/home/jrose/Zotero/storage/U5Y6XK2Z/PhysRevB.56.html:text/html;Eingereichte Version:/home/jrose/Zotero/storage/884NWSFG/Hanisch et al. - 1997 - Lattice dependence of saturated ferromagnetism in the Hubbard model.pdf:application/pdf},
}

